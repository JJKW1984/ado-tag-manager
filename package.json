{
  "name": "ado-tag-manager",
  "version": "0.2.7",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "package": "tfx extension create --manifest-globs azure-devops-extension.json",
    "manifest:test": "node scripts/create-manifest-variant.cjs test",
    "package:test": "pnpm run manifest:test && tfx extension create --manifest-globs azure-devops-extension.test.json",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.269.1",
    "azure-devops-extension-sdk": "^4.2.0",
    "azure-devops-ui": "^2.167.0",
    "react": "16.14.0",
    "react-dom": "16.14.0",
    "tfx-cli": "^0.23.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "16.14.0",
    "@types/react-dom": "^16.9.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "sass": "^1.70.0",
    "sass-loader": "^14.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "reporters": [
      "default",
      ["jest-junit", { "outputDirectory": "test-results", "outputName": "junit.xml" }]
    ],
    "coverageReporters": ["lcov", "json", "text-summary"],
    "collectCoverageFrom": ["src/**/*.{ts,tsx}", "!src/**/*.d.ts"],
    "moduleNameMapper": {
      "\\.(css|scss)$": "identity-obj-proxy"
    }
  }
}
